# Node.js server environment variables — copy to .env and fill in real values

PORT=4000
ALLOWED_ORIGIN=http://localhost:5173

# cSMS API (https://app.mycsms.com)
SMS_API=your_csms_bearer_token_here
SENDER_ID=YOURBRAND

# Admin alert phone (receives SMS when chat bot has no answer)
ADMIN_ALERT_PHONE=+233xxxxxxxxx

# Paystack
PAYSTACK_SECRET_KEY=sk_test_or_live_key_here
PAYSTACK_PUBLIC_KEY=pk_test_or_live_key_here
